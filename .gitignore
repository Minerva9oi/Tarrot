.DS_Store
Thumbs.db
Desktop.ini

# Crash reports
sysinfo.txt

# Build output archives
*.apk
*.aab
*.unitypackage
*.app

# Local package cache
[Pp]ackages/[Ll]ocal[Pp]ackages/

# Logs and temporary files
*.log
*.tmp

# Important:
# Do not ignore Unity .meta files. They preserve asset references and must be committed.
